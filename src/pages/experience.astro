---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import SectionWrapper from '../components/global/SectionWrapper.astro';
import Timeline from '../components/sections/Timeline.astro';

const experienceEntry = await getEntry('experience', 'experience');
---

<BaseLayout title={experienceEntry.data.title} description={experienceEntry.data.description}>
  <PageHeader
    title={experienceEntry.data.title}
    description="From neuroscience research to enterprise AI engineering."
  />

  <SectionWrapper variant="light" width="container">
    <Timeline entries={experienceEntry.data.entries} />
  </SectionWrapper>
</BaseLayout>
