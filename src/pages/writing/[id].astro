---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionWrapper from '../../components/global/SectionWrapper.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <SectionWrapper variant="light" width="content">
    <header class="post-header">
      <p class="post-header__date">{formatDate(post.data.date)}</p>
      <h1 class="post-header__title">{post.data.title}</h1>
      {post.data.tags.length > 0 && (
        <ul class="post-header__tags">
          {post.data.tags.map((tag) => (
            <li class="post-header__tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <article class="prose">
      <Content />
    </article>
  </SectionWrapper>
</BaseLayout>

<style>
  .post-header {
    padding-top: var(--space-section-lg);
    margin-bottom: var(--space-component);
  }

  .post-header__date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted-light);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
  }

  .post-header__title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .post-header__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent-dark);
    letter-spacing: var(--tracking-wide);
    background-color: var(--color-accent-subtle);
    padding: var(--space-1) var(--space-2);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .post-header__title {
      font-size: var(--text-3xl);
    }
  }
</style>
