---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/sections/PageHeader.astro';
import SectionWrapper from '../../components/global/SectionWrapper.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';

const base = import.meta.env.BASE_URL;

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Projects" description="Things I've built.">
  <PageHeader title="Projects" description="Things I've built — AI systems, software, experiments, and tools." />

  <SectionWrapper variant="light" width="wide">
    <div class="project-grid reveal-stagger">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          href={`${base}projects/${project.id}`}
          image={project.data.image}
          variant="light"
        />
      ))}
    </div>
  </SectionWrapper>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-grid-gap);
  }

  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
