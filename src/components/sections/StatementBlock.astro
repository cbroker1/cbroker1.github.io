---
interface Props {
  statement: string;
}

const { statement } = Astro.props;
---

<section class="statement-block">
  <div class="statement-block__inner container container--content">
    <p class="statement-block__text reveal">{statement}</p>
  </div>
  <div class="statement-block__fade" aria-hidden="true"></div>
</section>

<style>
  .statement-block {
    position: relative;
    padding-block: var(--space-40);
    background-color: var(--color-bg-dark);
    color: var(--color-text-on-dark);
  }

  .statement-block__text {
    font-size: var(--text-4xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    text-align: center;
    color: var(--color-text-on-dark);
  }

  /* Concentrated transition band at the bottom edge, so the dark→light
     handoff feels intentional rather than smeared across the section. */
  .statement-block__fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 96px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--color-bg-light) 100%
    );
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .statement-block {
      padding-block: var(--space-32);
    }

    .statement-block__text {
      font-size: var(--text-2xl);
    }
  }
</style>
