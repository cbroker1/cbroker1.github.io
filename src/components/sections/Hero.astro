---
---

<section class="hero">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
  >
    <source src="/video/hero.webm" type="video/webm" />
  </video>
  <div class="hero__info">
    <h1 class="hero__name">Carl Broker</h1>
    <p class="hero__detail">Agentic AI Engineer, IBM</p>
    <p class="hero__detail">Duluth, Minnesota</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Info block: vertically centered, shifted to the right side
     to avoid overlapping the video subject. */
  .hero__info {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    right: max(var(--padding-container), calc((100% - var(--width-wide)) / 2 + var(--padding-container)));
    z-index: 1;
    text-align: right;
  }

  .hero__name {
    font-size: var(--text-3xl);
    font-weight: var(--weight-semibold);
    color: #1a1a1a;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .hero__detail {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: #1a1a1a;
    letter-spacing: var(--tracking-wide);
    margin-top: var(--space-1);
  }

  @media (max-width: 768px) {
    .hero__info {
      top: auto;
      bottom: var(--space-12);
      right: var(--padding-container);
      transform: none;
    }

    .hero__name {
      font-size: var(--text-2xl);
    }
  }
</style>
